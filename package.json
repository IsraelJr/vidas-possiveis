{
  "name": "vidas-possiveis",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @vidas-possiveis/web dev",
    "build": "pnpm --filter @vidas-possiveis/web build",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "test:e2e": "pnpm --filter @vidas-possiveis/web test:e2e",
    "audit:sprint0": "node scripts/audit-sprint0.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "eslint": "^9.35.0",
    "eslint-config-next": "^15.5.0",
    "typescript": "^5.8.3"
  }
}
